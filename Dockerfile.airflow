FROM apache/airflow:2.8.4-python3.10

COPY --from=ghcr.io/astral-sh/uv:latest /uv /uvx /bin/

USER airflow

COPY --chown=airflow:airflow pyproject.toml uv.lock README.md ./

# Export exact pinned versions from the lock file (no re-resolution, avoids
# conflicts with Airflow's pre-installed packages) then install them.
RUN uv export --frozen --no-dev --no-emit-project -o /tmp/requirements.txt \
    && uv pip install --system --no-cache -r /tmp/requirements.txt
