FROM python:3.12-slim AS builder

COPY --from=ghcr.io/astral-sh/uv:latest /uv /uvx /bin/

WORKDIR /app

# Install CPU-only torch first to avoid downloading multi-GB CUDA packages
RUN uv venv /opt/venv && \
    uv pip install --no-cache \
    --python /opt/venv/bin/python \
    --index-url https://download.pytorch.org/whl/cpu \
    "torch" && \
    uv pip install --no-cache \
    --python /opt/venv/bin/python \
    "fastapi" \
    "uvicorn[standard]" \
    "pydantic" \
    "prometheus-fastapi-instrumentator" \
    "prometheus-client" \
    "httpx" \
    "scikit-learn" \
    "numpy" \
    "pymongo" \
    "python-dotenv" \
    "sentence-transformers" \
    "sentencepiece" \
    "transformers"

# --- Runtime ---
FROM python:3.12-slim AS runtime

WORKDIR /app

# Install Node.js (LTS) and the claude CLI
SHELL ["/bin/bash", "-o", "pipefail", "-c"]
RUN apt-get update && \
    apt-get install -y --no-install-recommends curl ca-certificates && \
    curl -fsSL https://deb.nodesource.com/setup_22.x | bash - && \
    apt-get install -y --no-install-recommends nodejs && \
    npm install -g @anthropic-ai/claude-code@2.1.187 && \
    apt-get clean && rm -rf /var/lib/apt/lists/*

COPY --from=builder /opt/venv /opt/venv

COPY shared/ ./shared/
COPY src/api/ ./src/api/

ENV PATH="/opt/venv/bin:$PATH"
ENV PYTHONPATH=/app

EXPOSE 8080

CMD ["uvicorn", "src.api.api:app", "--host", "0.0.0.0", "--port", "8080"]
