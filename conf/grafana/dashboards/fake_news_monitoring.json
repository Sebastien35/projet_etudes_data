{
  "title": "Fake News Detector — Monitoring",
  "uid": "fakenews-monitoring",
  "schemaVersion": 38,
  "version": 1,
  "timezone": "browser",
  "time": { "from": "now-1h", "to": "now" },
  "refresh": "30s",
  "tags": ["fakenews", "kedro", "api", "model"],
  "panels": [

    {
      "id": 1,
      "title": "Total Requests",
      "type": "stat",
      "gridPos": { "x": 0, "y": 0, "w": 6, "h": 4 },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background", "graphMode": "none" },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "blue", "value": null }] }
        }
      },
      "targets": [{
        "datasource": "Prometheus",
        "expr": "sum(http_requests_total{handler=~\".*/ask.*\"})",
        "legendFormat": "Requests"
      }]
    },

    {
      "id": 2,
      "title": "Request Rate (req/min)",
      "type": "stat",
      "gridPos": { "x": 6, "y": 0, "w": 6, "h": 4 },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background", "graphMode": "area" },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "decimals": 2,
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }] }
        }
      },
      "targets": [{
        "datasource": "Prometheus",
        "expr": "round(sum(rate(http_requests_total{handler=~\".*/ask.*\"}[5m])) * 60, 0.01)",
        "legendFormat": "req/min"
      }]
    },

    {
      "id": 3,
      "title": "Error Rate",
      "type": "stat",
      "gridPos": { "x": 12, "y": 0, "w": 6, "h": 4 },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background", "graphMode": "none" },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "decimals": 1,
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 1 },
              { "color": "red", "value": 5 }
            ]
          }
        }
      },
      "targets": [{
        "datasource": "Prometheus",
        "expr": "sum(rate(http_requests_total{handler=~\".*/ask.*\", status=~\"5..\"}[5m])) / sum(rate(http_requests_total{handler=~\".*/ask.*\"}[5m])) * 100",
        "legendFormat": "Error %"
      }]
    },

    {
      "id": 4,
      "title": "RAG Hit Rate",
      "type": "stat",
      "gridPos": { "x": 18, "y": 0, "w": 6, "h": 4 },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background", "graphMode": "none" },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "decimals": 1,
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 40 },
              { "color": "green", "value": 70 }
            ]
          }
        }
      },
      "targets": [{
        "datasource": "Prometheus",
        "expr": "sum(fakenews_retrieval_total{source=\"rag\"}) / sum(fakenews_retrieval_total) * 100",
        "legendFormat": "RAG hit %"
      }]
    },

    {
      "id": 5,
      "title": "HTTP Latency (P50 / P95 / P99)",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 4, "w": 12, "h": 8 },
      "fieldConfig": {
        "defaults": { "unit": "s", "custom": { "lineWidth": 2 } }
      },
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "histogram_quantile(0.50, rate(http_request_duration_seconds_bucket{handler=~\".*/ask.*\"}[5m]))",
          "legendFormat": "P50"
        },
        {
          "datasource": "Prometheus",
          "expr": "histogram_quantile(0.95, rate(http_request_duration_seconds_bucket{handler=~\".*/ask.*\"}[5m]))",
          "legendFormat": "P95"
        },
        {
          "datasource": "Prometheus",
          "expr": "histogram_quantile(0.99, rate(http_request_duration_seconds_bucket{handler=~\".*/ask.*\"}[5m]))",
          "legendFormat": "P99"
        }
      ]
    },

    {
      "id": 6,
      "title": "LLM Latency — RAG + Generation (P50 / P95)",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 4, "w": 12, "h": 8 },
      "fieldConfig": {
        "defaults": { "unit": "s", "custom": { "lineWidth": 2 } }
      },
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "histogram_quantile(0.50, rate(fakenews_llm_latency_seconds_bucket[5m]))",
          "legendFormat": "P50"
        },
        {
          "datasource": "Prometheus",
          "expr": "histogram_quantile(0.95, rate(fakenews_llm_latency_seconds_bucket[5m]))",
          "legendFormat": "P95"
        }
      ]
    },

    {
      "id": 7,
      "title": "Verdict Distribution",
      "type": "piechart",
      "gridPos": { "x": 0, "y": 12, "w": 8, "h": 9 },
      "options": { "pieType": "donut", "legendDisplayMode": "table", "legendPlacement": "right" },
      "targets": [
        { "datasource": "Prometheus", "expr": "fakenews_verdict_total{verdict=\"true\"}", "legendFormat": "True" },
        { "datasource": "Prometheus", "expr": "fakenews_verdict_total{verdict=\"very likely true\"}", "legendFormat": "Very Likely True" },
        { "datasource": "Prometheus", "expr": "fakenews_verdict_total{verdict=\"uncertain\"}", "legendFormat": "Uncertain" },
        { "datasource": "Prometheus", "expr": "fakenews_verdict_total{verdict=\"very likely false\"}", "legendFormat": "Very Likely False" },
        { "datasource": "Prometheus", "expr": "fakenews_verdict_total{verdict=\"false\"}", "legendFormat": "False" }
      ]
    },

    {
      "id": 8,
      "title": "Verdicts Over Time",
      "type": "timeseries",
      "gridPos": { "x": 8, "y": 12, "w": 16, "h": 9 },
      "fieldConfig": {
        "defaults": { "unit": "short", "custom": { "lineWidth": 2, "fillOpacity": 15 } }
      },
      "options": { "tooltip": { "mode": "multi" } },
      "targets": [
        { "datasource": "Prometheus", "expr": "rate(fakenews_verdict_total{verdict=\"true\"}[5m])", "legendFormat": "True" },
        { "datasource": "Prometheus", "expr": "rate(fakenews_verdict_total{verdict=\"very likely true\"}[5m])", "legendFormat": "Very Likely True" },
        { "datasource": "Prometheus", "expr": "rate(fakenews_verdict_total{verdict=\"uncertain\"}[5m])", "legendFormat": "Uncertain" },
        { "datasource": "Prometheus", "expr": "rate(fakenews_verdict_total{verdict=\"very likely false\"}[5m])", "legendFormat": "Very Likely False" },
        { "datasource": "Prometheus", "expr": "rate(fakenews_verdict_total{verdict=\"false\"}[5m])", "legendFormat": "False" }
      ]
    },

    {
      "id": 9,
      "title": "RAG vs Fallback Over Time",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 21, "w": 12, "h": 8 },
      "fieldConfig": {
        "defaults": { "unit": "short", "custom": { "lineWidth": 2, "fillOpacity": 20 } }
      },
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "rate(fakenews_retrieval_total{source=\"rag\"}[5m])",
          "legendFormat": "RAG (context sufficient)"
        },
        {
          "datasource": "Prometheus",
          "expr": "rate(fakenews_retrieval_total{source=\"general_knowledge\"}[5m])",
          "legendFormat": "Fallback (general knowledge)"
        },
        {
          "datasource": "Prometheus",
          "expr": "rate(fakenews_retrieval_total{source=\"error\"}[5m])",
          "legendFormat": "Error"
        }
      ]
    },

    {
      "id": 10,
      "title": "RAG Context Quality (chars retrieved)",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 21, "w": 12, "h": 8 },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": { "lineWidth": 2 },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 200 },
              { "color": "green", "value": 300 }
            ]
          }
        }
      },
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "histogram_quantile(0.50, rate(fakenews_rag_context_chars_bucket[5m]))",
          "legendFormat": "P50 context chars"
        },
        {
          "datasource": "Prometheus",
          "expr": "histogram_quantile(0.95, rate(fakenews_rag_context_chars_bucket[5m]))",
          "legendFormat": "P95 context chars"
        },
        {
          "datasource": "Prometheus",
          "expr": "300",
          "legendFormat": "Min sufficient threshold (300 chars)"
        }
      ]
    },

    {
      "id": 11,
      "title": "CPU Usage",
      "type": "gauge",
      "gridPos": { "x": 0, "y": 29, "w": 8, "h": 5 },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "showThresholdLabels": false, "showThresholdMarkers": true },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0, "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 70 },
              { "color": "red", "value": 90 }
            ]
          }
        }
      },
      "targets": [{
        "datasource": "Prometheus",
        "expr": "100 - (avg(irate(node_cpu_seconds_total{mode=\"idle\"}[5m])) * 100)",
        "legendFormat": "CPU %"
      }]
    },

    {
      "id": 12,
      "title": "RAM Usage",
      "type": "gauge",
      "gridPos": { "x": 8, "y": 29, "w": 8, "h": 5 },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "showThresholdLabels": false, "showThresholdMarkers": true },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0, "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 75 },
              { "color": "red", "value": 90 }
            ]
          }
        }
      },
      "targets": [{
        "datasource": "Prometheus",
        "expr": "(node_memory_MemTotal_bytes - node_memory_MemAvailable_bytes) / node_memory_MemTotal_bytes * 100",
        "legendFormat": "RAM %"
      }]
    },

    {
      "id": 13,
      "title": "Disk Usage",
      "type": "gauge",
      "gridPos": { "x": 16, "y": 29, "w": 8, "h": 5 },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "showThresholdLabels": false, "showThresholdMarkers": true },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0, "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 75 },
              { "color": "red", "value": 90 }
            ]
          }
        }
      },
      "targets": [{
        "datasource": "Prometheus",
        "expr": "(node_filesystem_size_bytes{mountpoint=\"/\",fstype!=\"tmpfs\"} - node_filesystem_free_bytes{mountpoint=\"/\",fstype!=\"tmpfs\"}) / node_filesystem_size_bytes{mountpoint=\"/\",fstype!=\"tmpfs\"} * 100",
        "legendFormat": "Disk %"
      }]
    },

    {
      "id": 14,
      "title": "CPU / RAM / Disk Over Time",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 34, "w": 24, "h": 8 },
      "fieldConfig": {
        "defaults": { "unit": "percent", "min": 0, "max": 100, "custom": { "lineWidth": 2 } }
      },
      "options": { "tooltip": { "mode": "multi" } },
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "100 - (avg(irate(node_cpu_seconds_total{mode=\"idle\"}[5m])) * 100)",
          "legendFormat": "CPU %"
        },
        {
          "datasource": "Prometheus",
          "expr": "(node_memory_MemTotal_bytes - node_memory_MemAvailable_bytes) / node_memory_MemTotal_bytes * 100",
          "legendFormat": "RAM %"
        },
        {
          "datasource": "Prometheus",
          "expr": "(node_filesystem_size_bytes{mountpoint=\"/\",fstype!=\"tmpfs\"} - node_filesystem_free_bytes{mountpoint=\"/\",fstype!=\"tmpfs\"}) / node_filesystem_size_bytes{mountpoint=\"/\",fstype!=\"tmpfs\"} * 100",
          "legendFormat": "Disk %"
        }
      ]
    }

  ]
}
